{
  "name": "hosts",
  "scopeName": "source.hosts",
  "patterns": [
    {
      "name": "comment.line.number-sign.hosts",
      "match": "#.*$"
    },
    {
      "name": "constant.numeric.ipv4.hosts",
      "match": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b"
    },
    {
      "name": "constant.numeric.ipv6.hosts",
      "match": "(?:[0-9a-fA-F]{1,4}:){2,7}[0-9a-fA-F]{0,4}|[0-9a-fA-F:]*::[0-9a-fA-F:]*"
    },
    {
      "name": "entity.name.hostname.hosts",
      "match": "[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?"
    }
  ]
}
