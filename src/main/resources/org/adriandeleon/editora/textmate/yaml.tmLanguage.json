{
  "name": "YAML",
  "scopeName": "source.yaml",
  "fileTypes": ["yml", "yaml"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keys" },
    { "include": "#strings" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.yaml",
      "match": "#.*$"
    },
    "keys": {
      "name": "entity.other.attribute-name.yaml",
      "match": "^[\\s-]*[A-Za-z0-9_.-]+(?=:)"
    },
    "strings": {
      "name": "string.quoted.double.yaml",
      "match": "\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*'"
    },
    "constants": {
      "name": "constant.language.yaml",
      "match": "\\b(?:true|false|yes|no|null)\\b"
    },
    "numbers": {
      "name": "constant.numeric.yaml",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    },
    "punctuation": {
      "name": "punctuation.definition.yaml",
      "match": "[:\\-\\[\\]{}.,]"
    }
  }
}

