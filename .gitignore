# Build output
target/
*.class
dist/

# Example plugin build artifacts
examples/*/*.jar
examples/*/*.zip
examples/*/.build/
examples/*/.zipstage/
examples/*/.classpath

# Maven
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Logs
*.log

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
*.code-workspace

# Claude Code local dev helper (settings.local.json is covered by global ignore)
.claude/launch.json

# Node (stray installs from npx-based tools like the Mermaid CLI / maid)
/node_modules/
/package-lock.json
/package.json

# OS
.DS_Store
Thumbs.db

# Generated large/perf samples (created by scripts/GenSamples.java)
/samples/perf/

# Build output from RUNNING the build-tool samples (samples/build-tools/* exist to be run, so this WILL
# appear). `target/` above already covers Maven/Cargo; these are the rest. SamplesCorpusTest honors this
# file, so generated output is never mistaken for an undocumented committed sample.
/samples/build-tools/cargo/Cargo.lock
/samples/build-tools/gradle/.gradle/
/samples/build-tools/gradle/build/
/samples/build-tools/go/go-demo
/samples/build-tools/npm/node_modules/

# Corpus log samples are intentionally tracked (the global *.log above would drop them)
!/samples/log/*.log
