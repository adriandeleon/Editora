#!/bin/sh
#
# Editora .deb postrm — OVERRIDES jpackage's generated DEB postrm. Undoes what postinst created:
# the `editora` PATH symlink (only if it still points into our install tree, so a foreign
# /usr/bin/editora is never touched) and the registered menu entry — on remove/purge.
#
set -e

case "$1" in
    remove|purge)
        if [ -L /usr/bin/editora ]; then
            case "$(readlink /usr/bin/editora 2>/dev/null || true)" in
                /opt/*/bin/Editora) rm -f /usr/bin/editora ;;
            esac
        fi
        rm -f /usr/share/applications/editora-Editora.desktop
        rm -f /usr/share/applications/editora-Editora-expert.desktop

        # Strip the Expert Mode default-handler lines postinst added to the system-wide
        # mimeapps.list; if nothing but section headers remains (i.e. postinst created the file),
        # remove it entirely.
        mimeapps=/usr/share/applications/mimeapps.list
        if [ -f "$mimeapps" ]; then
            tmp=$(mktemp)
            grep -v '=editora-Editora-expert\.desktop$' "$mimeapps" > "$tmp" || true
            if grep -q '=' "$tmp"; then
                mv "$tmp" "$mimeapps"
                chmod 0644 "$mimeapps"
            else
                rm -f "$mimeapps" "$tmp"
            fi
        fi
        ;;
esac

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database -q /usr/share/applications 2>/dev/null || true
fi

exit 0
