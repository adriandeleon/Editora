#!/bin/sh
#
# Editora .deb postinst — OVERRIDES jpackage's generated DEB postinst (jpackage picks up any file
# named "postinst" in --resource-dir).
#
# It does what jpackage's default script did (register the menu entry) PLUS two extras:
#   1. an `editora` command on PATH (jpackage installs the launcher only at /opt/<pkg>/bin/Editora);
#   2. a StartupWMClass on the menu entry so the *running* window also picks up our icon.
#
# Background: jpackage installs the .desktop + icon only under /opt/<pkg>/lib/ and relies on its
# postinst to register them system-wide. Since we replace postinst we must do that here, or the
# launcher is never installed into /usr/share/applications and the app shows the generic Java icon.
# The bundled .desktop's Icon= is already an absolute path to our PNG, so once it's registered the
# menu shows our icon — we just copy it into /usr/share/applications. The bundled entry comes from
# our own template override (packaging/linux/Editora.desktop, staged into the DEB wrap's resource
# dir by scripts/aot_build.java) and already carries StartupWMClass/MimeType/Exec %F, so the copy
# normally takes the verbatim fast path; the awk StartupWMClass injection below is kept as a
# fallback for a build where the template override didn't take.
#
set -e

case "$1" in
    configure)
        # 1) PATH command — install dir is /opt/<package-name> (jpackage lowercases it).
        for launcher in /opt/*/bin/Editora; do
            if [ -x "$launcher" ]; then
                ln -sf "$launcher" /usr/bin/editora
                break
            fi
        done

        # 2) Register the menu entry system-wide, injecting StartupWMClass if the source lacks it.
        for src in /opt/*/lib/editora-Editora.desktop; do
            [ -f "$src" ] || continue
            mkdir -p /usr/share/applications
            if grep -q '^StartupWMClass=' "$src"; then
                cp -f "$src" /usr/share/applications/editora-Editora.desktop
            else
                # WM_CLASS is com.editora.App (JavaFX derives it from the module main); must match
                # exactly or GNOME won't bind the running window to this entry (verified via wmctrl -lx).
                awk '{ print }
                     /^\[Desktop Entry\]/ && !added { print "StartupWMClass=com.editora.App"; added = 1 }' \
                    "$src" > /usr/share/applications/editora-Editora.desktop
            fi
            chmod 0644 /usr/share/applications/editora-Editora.desktop
            break
        done

        # 3) Second menu entry: "Editora Expert Mode" — the same app launched with
        #    --expert --single-window. Derived from the just-registered primary entry so it always
        #    tracks the real launcher path/icon. StartupWMClass is dropped: both entries launch the
        #    same WM_CLASS (com.editora.App) and only one .desktop may claim it, or GNOME binds the
        #    running window/dock icon to an arbitrary entry — the primary keeps it. MimeType lists
        #    the concrete text types (canonical shared-mime-info names) so this entry can be the
        #    DEFAULT for them in step 4; types not listed still reach it via the text/plain
        #    subclass fallback. text/html and image/svg+xml are deliberately excluded (browser /
        #    image viewer keep those).
        mime_types="text/plain text/markdown text/csv text/tab-separated-values text/css \
text/javascript text/rust text/x-python text/x-go text/x-java text/x-csrc text/x-c++src \
text/x-chdr text/x-c++hdr text/x-makefile text/x-log text/x-lua text/x-kotlin text/x-csharp \
application/json application/yaml application/toml application/xml application/sql \
application/x-shellscript application/x-ruby application/x-php application/x-perl"
        primary=/usr/share/applications/editora-Editora.desktop
        expert=/usr/share/applications/editora-Editora-expert.desktop
        if [ -f "$primary" ]; then
            mime_line=$(printf '%s;' $mime_types)
            if grep -q '^Exec=.*%F' "$primary"; then
                exec_expr='s/^Exec=\(.*\) %F$/Exec=\1 --expert --single-window %F/'
            else
                exec_expr='s/^Exec=\(.*\)$/Exec=\1 --expert --single-window %F/'
            fi
            sed -e 's/^Name=.*/Name=Editora Expert Mode/' \
                -e 's/^Comment=.*/Comment=Editora with minimal chrome, one window (--expert --single-window)/' \
                -e "$exec_expr" \
                -e '/^StartupWMClass=/d' \
                -e "s|^MimeType=.*|MimeType=$mime_line|" \
                "$primary" > "$expert"
            chmod 0644 "$expert"
        fi

        # 4) Make Expert Mode the system-wide default handler for text files: a
        #    [Default Applications] entry per type in /usr/share/applications/mimeapps.list (the
        #    freedesktop mime-apps mechanism GIO honors for distro/system defaults). A user's own
        #    ~/.config/mimeapps.list choice still wins — deliberately, per Debian convention.
        if [ -f "$expert" ]; then
            mimeapps=/usr/share/applications/mimeapps.list
            tmp=$(mktemp)
            # Start from the existing file minus any line already pointing at the expert entry
            # (idempotent across upgrades/reinstalls).
            if [ -f "$mimeapps" ]; then
                grep -v '=editora-Editora-expert\.desktop$' "$mimeapps" > "$tmp" || true
            fi
            grep -q '^\[Default Applications\]' "$tmp" || printf '[Default Applications]\n' >> "$tmp"
            # Insert our defaults right under the header, dropping a competing default for the
            # same type (a duplicated key in a keyfile is undefined — never leave two).
            awk -v id=editora-Editora-expert.desktop -v types="$mime_types" '
                BEGIN { n = split(types, t, " "); for (i = 1; i <= n; i++) mine[t[i]] = 1 }
                /^\[Default Applications\]$/ {
                    print
                    for (i = 1; i <= n; i++) print t[i] "=" id
                    insection = 1
                    next
                }
                /^\[/ { insection = 0 }
                {
                    if (insection) {
                        eq = index($0, "=")
                        if (eq > 0 && (substr($0, 1, eq - 1) in mine)) next
                    }
                    print
                }
            ' "$tmp" > "$mimeapps"
            rm -f "$tmp"
            chmod 0644 "$mimeapps"
        fi
        ;;
esac

# Refresh the desktop database so the launcher + icon show up without a re-login.
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database -q /usr/share/applications 2>/dev/null || true
fi

exit 0
