# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java is formatted by Palantir Java Format (4-space indent, 120-column limit) via Spotless.
[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{xml,fxml}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.css]
indent_size = 4

# Shell scripts in scripts/ are tab-indented.
[*.sh]
indent_style = tab

# Makefiles require real tabs.
[Makefile]
indent_style = tab

# Markdown uses trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# i18n property files: keys/values verbatim, no width limit.
[*.properties]
max_line_length = off
