; Editora git-config sample — highlighted by the `git-config` grammar (matched by the `.gitconfig` suffix).
[user]
	name = Ada Lovelace
	email = ada@example.com
[core]
	editor = editora
	autocrlf = input
	pager = less -FRX
[alias]
	co = checkout
	st = status
	lg = log --oneline --graph --decorate
[color]
	ui = auto
[push]
	default = simple
[url "git@github.com:"]
	insteadOf = https://github.com/
