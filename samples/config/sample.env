# Editora dotenv sample — highlighted by the `dotenv` grammar (matched by the `.env` suffix).
# Fake values only; this file is inert (not at the repo root, never loaded).
APP_NAME=Editora
APP_ENV=development
DEBUG=true
PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/editora
API_TOKEN=fake-token-not-a-real-secret

# quoted value with spaces
GREETING="hello world"

# a reference to another variable
LOG_DIR=${HOME}/logs

export SECRET_KEY=change-me
