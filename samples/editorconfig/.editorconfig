# Hermetic fixture: root=true stops inheritance from the repo .editorconfig so
# these files exercise EditorConfig in isolation.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.txt]
end_of_line = crlf
max_line_length = 40
